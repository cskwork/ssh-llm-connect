# Per-host SSH config template
# Usage:
#   1) cp _template.env <alias>.env  (e.g. prod-app.env)
#   2) fill in values
#   3) ./bin/connect.sh <alias> "<readonly command>"

# ── required ──────────────────────────
SSH_HOST=
SSH_PORT=22
SSH_USER=

# ── auth (use one) ────────────────────
SSH_KEY_PATH=
SSH_PASSWORD=

# ── optional ──────────────────────────
SSH_PROXY_JUMP=
SSH_REMOTE_PATH=
SSH_LOCAL_FORWARD=
SSH_REMOTE_FORWARD=
SSH_EXTRA_OPTS=
